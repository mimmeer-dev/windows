{
  "name": "Windows 10 LTSC",
  "service": "windows",
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--stop-timeout=120",
    // Mounts the workspace's `./windows` folder to `/storage` to persist your data!
    "--volume=${localWorkspaceFolder}/windows:/storage"
  ],
  "overrideCommand": false,
  "containerEnv": {
    "VERSION": "10l",
    "USERNAME": "Administrator",
    "PASSWORD": "",
    "KVM": "N",             // Software emulation mode (KVM is not available on Codespaces)
    "RAM_SIZE": "10G",       // Lowers RAM usage so Codespaces doesn't crash from Out-of-Memory
    "CPU_CORES": "3",
    "DHCP": "no"            // Turn off DHCP helper scripts to avoid needing NET_ADMIN
  },
  "forwardPorts": [8006],  
  "portsAttributes": {
    "8006": {
      "label": "Web",
      "onAutoForward": "notify"
    }
  },
  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  }, 
  "dockerComposeFile": "codespaces.yml", // why did this not be default
  "initializeCommand": "docker system prune --all --force"
}
